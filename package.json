{
  "name": "raven",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/core",
    "packages/web",
    "packages/skills/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/core && npm run build -ws --if-present",
    "dev": "concurrently -n core,web -c blue,green \"npm run dev:core\" \"npm run dev:web\"",
    "dev:core": "npm run dev -w packages/core",
    "dev:web": "npm run dev -w packages/web",
    "start:core": "npm run start -w packages/core",
    "lint": "eslint packages/*/src packages/skills/*/src && tsc --noEmit -p packages/shared && tsc --noEmit -p packages/core",
    "lint:fix": "eslint --fix packages/*/src packages/skills/*/src",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}' 'packages/skills/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}' 'packages/skills/*/src/**/*.ts'",
    "check:strip-types": "bash scripts/check-strip-types.sh",
    "check": "npm run format:check && npm run lint && npm run check:strip-types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
