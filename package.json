{
  "name": "raven",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/core",
    "packages/web",
    "packages/mcp-ticktick",
    "packages/mcp-google-workspace"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/core && npm run build -ws --if-present",
    "dev": "concurrently -n core,web -c blue,green \"npm run dev:core\" \"npm run dev:web\"",
    "dev:core": "npm run dev -w packages/core",
    "dev:web": "npm run dev -w packages/web",
    "start:core": "npm run start -w packages/core",
    "lint": "eslint --max-warnings 0 packages/*/src && tsc --noEmit -p packages/shared && tsc --noEmit -p packages/core",
    "lint:fix": "eslint --fix packages/*/src",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "check:strip-types": "bash scripts/check-strip-types.sh",
    "check": "npm run format:check && npm run lint && npm run check:strip-types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mcp": "vitest run --project mcp-ticktick",
    "test:mcp:watch": "vitest --project mcp-ticktick",
    "test:skill": "node --experimental-strip-types scripts/test-skill.ts",
    "test:ticktick": "node --experimental-strip-types scripts/test-ticktick-manual.ts",
    "test:suite": "node --experimental-strip-types scripts/test-suite.ts",
    "test:suite:list": "node --experimental-strip-types scripts/test-suite.ts --list",
    "update:gws": "bash scripts/update-gws-skills.sh"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "grammy": "^1.41.1",
    "imapflow": "^1.2.15"
  }
}
