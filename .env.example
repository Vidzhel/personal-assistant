# ── Claude API ──────────────────────────────────────────────
# If using MAX plan: leave ANTHROPIC_API_KEY empty/unset.
# The SDK uses `claude` CLI auth automatically (run `claude login` first).
# If using API credits: set your key here instead.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# ── TickTick ────────────────────────────────────────────────
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_ACCESS_TOKEN=

# ── Gmail IMAP (App Password) ──────────────────────────────
GMAIL_IMAP_USER=you@gmail.com
GMAIL_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Gmail MCP (OAuth - used by sub-agents) ─────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Group mode (optional — enables topic threads)
TELEGRAM_GROUP_ID=                    # Telegram group/supergroup ID (negative number)
TELEGRAM_TOPIC_GENERAL=              # General topic thread ID (usually 1)
TELEGRAM_TOPIC_SYSTEM=               # System alerts topic thread ID
TELEGRAM_TOPIC_MAP=                  # JSON: topicName → threadId, e.g. '{"Work":5,"Personal":7}'

# ── Google Workspace (gws CLI) ────────────────────────────
GWS_PRIMARY_CREDENTIALS_FILE=           # Path to primary gws credentials JSON (gws auth export --unmasked)
GWS_SECONDARY_CREDENTIALS_FILE=        # Path to second account credentials JSON (optional)
GWS_GCP_PROJECT_ID=                     # GCP project ID for Gmail Pub/Sub watch
GWS_DRIVE_POLL_INTERVAL_MS=300000       # Drive changes poll interval (default 5 min)

# ── Google Gemini (Voice Transcription) ───────────────────
GOOGLE_API_KEY=

# ── Raven System ────────────────────────────────────────────
RAVEN_PORT=4001
RAVEN_TIMEZONE=Europe/London
RAVEN_DIGEST_TIME=08:00
RAVEN_MAX_CONCURRENT_AGENTS=3
RAVEN_MAX_BUDGET_USD_PER_DAY=5.00
DATABASE_PATH=./data/raven.db
SESSION_PATH=./data/sessions
LOG_LEVEL=info
