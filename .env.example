# ── Claude API ──────────────────────────────────────────────
# If using MAX plan: leave ANTHROPIC_API_KEY empty/unset.
# The SDK uses `claude` CLI auth automatically (run `claude login` first).
# If using API credits: set your key here instead.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# ── TickTick ────────────────────────────────────────────────
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_ACCESS_TOKEN=

# ── Gmail IMAP (App Password) ──────────────────────────────
GMAIL_IMAP_USER=you@gmail.com
GMAIL_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Gmail MCP (OAuth - used by sub-agents) ─────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Raven System ────────────────────────────────────────────
RAVEN_PORT=3001
RAVEN_TIMEZONE=Europe/London
RAVEN_DIGEST_TIME=08:00
RAVEN_MAX_CONCURRENT_AGENTS=3
RAVEN_MAX_BUDGET_USD_PER_DAY=5.00
DATABASE_PATH=./data/raven.db
SESSION_PATH=./data/sessions
LOG_LEVEL=info
