{
  "mcpServers": {
    "gws-primary": {
      "command": "node",
      "args": ["--experimental-strip-types", "packages/mcp-google-workspace/src/index.ts"],
      "env": {
        "GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE": "${GWS_PRIMARY_CREDENTIALS_FILE}"
      }
    },
    "gws-meet": {
      "command": "node",
      "args": ["--experimental-strip-types", "packages/mcp-google-workspace/src/index.ts"],
      "env": {
        "GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE": "${GWS_MEET_CREDENTIALS_FILE}"
      }
    }
  }
}
